            pa.point_name,
            pa.route_id,
            pa.route_name,
            cpc.id_cliente,
            cpc.client_name,
            cpc.prioridad
        FROM PuntosActivos pa
        LEFT JOIN ClientesPorPunto cpc ON pa.point_id = cpc.point_id
        ORDER BY cpc.client_name, pa.route_name, pa.point_name, cpc.prioridad DESC
        
